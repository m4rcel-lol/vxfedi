# vxfedi — Caddy reverse proxy
#
# Add this block to your existing /etc/caddy/Caddyfile (or save it as one),
# swap in your domain, then reload:  sudo systemctl reload caddy
#
# That's all you need. Caddy automatically provisions HTTPS, redirects
# HTTP -> HTTPS, and forwards the Host / X-Forwarded-* headers that vxfedi
# relies on (the app runs with Express "trust proxy" enabled).

vx.yourdomain.tld {
    reverse_proxy localhost:41530
}

# ---------------------------------------------------------------------------
# Optional extras — uncomment only if you want them:
#
# vx.yourdomain.tld {
#     reverse_proxy localhost:41530
#     encode gzip zstd                 # compress responses
#     request_body { max_size 1MB }    # cap request size
#     log { output file /var/log/caddy/vxfedi.log }
# }
#
# Redirect www -> apex:
# www.vx.yourdomain.tld {
#     redir https://vx.yourdomain.tld{uri} permanent
# }
