# vxfedi Configuration

# Server Configuration
PORT=3000
NODE_ENV=production

# Base URL for your vxfedi instance (e.g., https://vx.yourdomain.tld)
BASE_URL=http://localhost:3000

# Optional: User Agent for API requests
USER_AGENT=vxfedi/1.0 (https://github.com/m4rcel-lol/vxfedi)

# Optional: Request timeout in milliseconds
REQUEST_TIMEOUT=10000

# Optional: Cache settings
CACHE_MAX_AGE=3600
